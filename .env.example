# =============================================================================
# DeskLumina Environment Configuration
# =============================================================================
# At least one provider API key is required. Set only the keys for providers
# you intend to use. Unused providers will not be registered at startup.
# =============================================================================

# --- Provider API Keys (set at least one) ------------------------------------

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=

# --- Model Configuration -----------------------------------------------------
# Format: provider:model (e.g. groq:llama-3.3-70b-versatile)
# The provider portion must match one of the registered providers above.
#
# Primary model (required: or configure via models.json)
DESKLUMINA_MODEL=

# Fallback models (optional: comma-separated, tried in order on failure)
# DESKLUMINA_FALLBACKS=groq:llama-3.3-70b-versatile,openrouter:openrouter/free, anthropic:claude-haiku-4-5 ,openai:gpt-5.4-mini, huggingface:meta-llama/Llama-3.3-70B-Instruct, gemini:gemini-2.5-flash

