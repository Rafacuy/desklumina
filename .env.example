# Required: Your Groq API key
GROQ_API_KEY=your_groq_api_key_here

# Required: Primary AI model to use
MODEL_NAME=openai/gpt-oss-120b

# Optional: Fallback models (comma-separated, used if primary model is unavailable)
# If not set, default fallbacks will be used: llama-3.3-70b-versatile, llama-3.1-8b-instant, gpt-oss-20b
FALLBACK_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,openai/gpt-oss-20b
