# =============================================================================
# DeskLumina Environment Configuration
# =============================================================================
# At least one provider API key is required. Set only the keys for providers
# you intend to use. Unused providers will not be registered at startup.
# =============================================================================

# --- Provider API Keys (set at least one) ------------------------------------

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=

# -- Web Search -- (set at least one)
#
# set one or more keys + DeskLumina will fall back if something goes down
# or rate limits. pick whatever u got

# SERPER_API_KEY=your_serper_key
# SERPAPI_API_KEY=your_serpapi_key
# TAVILY_API_KEY=your_tavily_key
# SEARXNG_BASE_URL=https://searx.example.com
#  if using a private searxng instance u might need auth headers
# SEARXNG_AUTH_HEADER_NAME=
# SEARXNG_AUTH_HEADER_VALUE=

# which provider to use by default. auto just picks the first one thats configured
# DESKLUMINA_WEB_SEARCH_PROVIDER=auto

# timeout for searches in ms. 2000-20000 is reasonable. if ur impatient go lower ¯\_(ツ)_/¯
# DESKLUMINA_WEB_SEARCH_TIMEOUT_MS=8000

# Model Configuration
# Format: provider:model (e.g. groq:llama-3.3-70b-versatile)
# The provider portion must match one of the registered providers above.
#
# Primary model (required: or configure via models.json)
DESKLUMINA_MODEL=

# Embedding model (optional: for RAG/semantic search features)
# Format: provider:model (e.g. openai:text-embedding-3-small)
DESKLUMINA_EMBED_MODEL=

# Fallback models (optional: comma-separated, tried in order on failure)
# DESKLUMINA_FALLBACKS=groq:llama-3.3-70b-versatile,openrouter:openrouter/free, anthropic:claude-haiku-4-5 ,openai:gpt-5.4-mini, huggingface:meta-llama/Llama-3.3-70B-Instruct, gemini:gemini-3.5-flash

