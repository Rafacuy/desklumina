{
  "name": "desklumina",
  "version": "1.26.7",
  "scripts": {
    "// DEV (source, transpile on-the-fly)": "",
    "start": "bun run src/main-launcher.ts",
    "dev": "bun --watch run src/main-launcher.ts --chat",
    "send": "bun run src/main-launcher.ts --send",
    "// PROD (compiled binary, no transpile)": "",
    "start:prod": "./bin/desklumina-launcher",
    "send:prod": "./bin/desklumina-launcher --send",
    "// BUILD": "",
    "build:launcher": "bun build ./src/main-launcher.ts --compile --outfile ./bin/desklumina-launcher --target bun --minify",
    "build": "bun run build:launcher",
    "// UTILS": "",
    "lint": "bun x tsc --noEmit",
    "version:sync": "bun run scripts/sync-version.ts",
    "version:set": "bun run scripts/bump-version.ts",
    "i18n:refactor": "bun run scripts/i18n-refactor.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:verbose": "bun test --verbose"
  },
  "dependencies": {
    "edge-tts-universal": "^1.4.0",
    "mathjs": "^15.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "description": "AI automation agent for Linux desktops"
}
