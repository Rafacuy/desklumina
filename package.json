{
  "name": "desklumina",
  "version": "1.2.0",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "description": "AI automation agent for Linux desktops",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch run src/main.ts --chat",
    "lint": "bun x tsc --noEmit",
    "daemon": "bun run src/main.ts --daemon",
    "daemon:start": "bun run src/main.ts --daemon &",
    "daemon:status": "bun run src/main.ts --daemon-status",
    "send": "bun run src/main.ts --send",
    "version:sync": "bun run scripts/sync-version.ts",
    "version:set": "bun run scripts/bump-version.ts",
    "i18n:refactor": "bun run scripts/i18n-refactor.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:verbose": "bun test --verbose"
  },
  "dependencies": {
    "edge-tts-universal": "^1.4.0"
  }
}
