{
  "name": "lumina",
  "version": "1.0.0",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "description": "AI automation agent for BSPWM",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch run src/main.ts --chat",
    "lint": "bun x tsc --noEmit",
    "daemon": "bun run src/main.ts --daemon",
    "daemon:start": "bun run src/main.ts --daemon &",
    "daemon:status": "bun run src/main.ts --daemon-status",
    "send": "bun run src/main.ts --send",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:verbose": "bun test --verbose"
  },
  "dependencies": {
    "edge-tts-universal": "^1.4.0"
  }
}
